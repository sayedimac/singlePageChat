@page "/"
@using Microsoft.AspNetCore.Components.Forms
@using System.Net.Http.Json
@using Microsoft.AspNetCore.Components.Web
@inject HttpClient Http
@inject IJSRuntime Js

<div class="chat-app">
    <aside class="chat-sidebar">
        <div class="brand">
            <h2>AI Chat</h2>
            <button class="btn btn-sm btn-light" @onclick="ClearConversation" disabled="@(messages.Count == 0)">New
                conversation</button>
        </div>

        <div class="sidebar-section">
            <span class="section-label">Agent</span>
            <div class="agent-pill">Foundry Assistant</div>
        </div>

        <div class="sidebar-section">
            <span class="section-label">Status</span>
            <div class="@GetStatusPillClass()">@(isBusy ? "Working..." : "Ready")</div>
        </div>
    </aside>

    <main class="chat-main">
        <header class="chat-header">
            <div>
                <h1>Foundry Chat</h1>
                <p>Fullscreen local chat shell for rapid iteration.</p>
            </div>

            <button class="btn btn-outline-secondary btn-sm" @onclick="ClearConversation"
                disabled="@(messages.Count == 0)">Clear chat</button>
        </header>

        <section class="chat-body" aria-live="polite">
            @if (messages.Count == 0)
            {
                <div class="chat-empty-state">
                    <h3>Welcome to AI Chat</h3>
                    <p>Send a message, upload a file, or record voice to kick off the conversation.</p>
                </div>
            }
            else
            {
                @foreach (var item in messages)
                {
                    <article class="@GetMessageRowClass(item.Role)">
                        <div class="message-role">@item.Role</div>
                        <div class="message-bubble">@item.Content</div>
                    </article>
                }
            }
        </section>

        <footer class="chat-footer">
            @if (!string.IsNullOrWhiteSpace(status))
            {
                <div class="status-line">@status</div>
            }

            <div class="composer">
                <InputFile id="chat-file" OnChange="UploadDocumentAsync" class="visually-hidden" />
                <label class="btn btn-outline-secondary" for="chat-file">Attach</label>

                <button class="btn btn-outline-secondary" @onclick="StartRecordingAsync"
                       disabled="@(isRecording || isBusy)" title="Start recording">
                    🎙️
                </button>

                <button class="btn btn-outline-secondary" @onclick="StopRecordingAsync"
                       disabled="@((!isRecording) || isBusy)" title="Stop recording">
                    ⏹️
                </button>

                <textarea class="form-control composer-input" rows="1"
                    placeholder="Type a message... (Enter to send, Shift+Enter for new line)" @bind="prompt"
                    @bind:event="oninput" @onkeydown="HandlePromptKeyDown"></textarea>

                <button class="btn btn-primary" @onclick="SendPromptAsync"
                       disabled="@(isBusy || string.IsNullOrWhiteSpace(prompt))">
                    Send
                </button>
            </div>
        </footer>
    </main>
</div>

@code {
    private readonly List<ChatItem> messages = [];
    private string? prompt;
    private string? status;
    private bool isBusy;
    private bool isRecording;

    private async Task SendPromptAsync()
    {
        if (string.IsNullOrWhiteSpace(prompt) || isBusy)
        {
            return;
        }

        var text = prompt.Trim();
        prompt = string.Empty;
        messages.Add(new ChatItem("You", text));
        status = "Sending...";
        isBusy = true;

        try
        {
            var response = await Http.PostAsJsonAsync("api/chat", new { message = text });
            if (!response.IsSuccessStatusCode)
            {
                status = $"Chat failed: {(int)response.StatusCode}";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<ChatResponse>();
            messages.Add(new ChatItem("Agent", payload?.Response ?? "No response body."));
            status = "Message delivered.";
        }
        catch (Exception ex)
        {
            status = $"Chat error: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task UploadDocumentAsync(InputFileChangeEventArgs args)
    {
        if (isBusy)
        {
            return;
        }

        var file = args.File;
        if (file is null)
        {
            status = "No file selected.";
            return;
        }

        isBusy = true;
        status = "Uploading document...";

        try
        {
            using var content = new MultipartFormDataContent();
            using var stream = file.OpenReadStream(25 * 1024 * 1024);
            using var streamContent = new StreamContent(stream);
            streamContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(file.ContentType);
            content.Add(streamContent, "file", file.Name);

            var response = await Http.PostAsync("api/chat/documents", content);
            if (!response.IsSuccessStatusCode)
            {
                status = $"Upload failed: {(int)response.StatusCode}";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<UploadResponse>();
            messages.Add(new ChatItem("System", payload?.Message ?? $"Uploaded {file.Name}."));
            status = "Document uploaded.";
        }
        catch (Exception ex)
        {
            status = $"Upload error: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task StartRecordingAsync()
    {
        if (isBusy || isRecording)
        {
            return;
        }

        await Js.InvokeVoidAsync("chatRecorder.start");
        isRecording = true;
        status = "Recording started.";
    }

    private async Task StopRecordingAsync()
    {
        if (isBusy || !isRecording)
        {
            return;
        }

        isBusy = true;

        try
        {
            var recording = await Js.InvokeAsync<RecordedAudio?>("chatRecorder.stop");
            isRecording = false;

            if (recording is null || string.IsNullOrWhiteSpace(recording.Base64))
            {
                status = "No recording captured.";
                return;
            }

            using var content = new MultipartFormDataContent();
            var bytes = Convert.FromBase64String(recording.Base64);
            using var fileContent = new ByteArrayContent(bytes);
            fileContent.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(recording.ContentType ??
            "audio/webm");
            content.Add(fileContent, "file", string.IsNullOrWhiteSpace(recording.FileName) ? "voice.webm" : recording.FileName);

            var response = await Http.PostAsync("api/chat/documents", content);
            if (!response.IsSuccessStatusCode)
            {
                status = $"Voice upload failed: {(int)response.StatusCode}";
                return;
            }

            var payload = await response.Content.ReadFromJsonAsync<UploadResponse>();
            messages.Add(new ChatItem("System", payload?.Message ?? "Voice message uploaded."));
            status = "Voice message uploaded.";
        }
        catch (Exception ex)
        {
            isRecording = false;
            status = $"Recording error: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task HandlePromptKeyDown(KeyboardEventArgs args)
    {
        if (args.Key == "Enter" && !args.ShiftKey)
        {
            await SendPromptAsync();
        }
    }

    private void ClearConversation()
    {
        messages.Clear();
        status = "Conversation cleared.";
        prompt = string.Empty;
        isRecording = false;
    }

    private static string GetMessageRowClass(string role)
        => role == "You" ? "message-row from-user" : "message-row from-agent";

    private string GetStatusPillClass()
        => isBusy ? "status-pill busy" : "status-pill idle";

    private sealed record ChatItem(string Role, string Content);
    private sealed record ChatResponse(string Response);
    private sealed record UploadResponse(string Message, string? DocumentId);
    private sealed record RecordedAudio(string? FileName, string? ContentType, string? Base64);
}

                                                               